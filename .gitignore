# Master .gitignore for CargoTrust (Next.js + Hardhat Monorepo)

# Dependencies
node_modules/
**/node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Next.js build outputs
web/.next/
web/out/
web/build/
web/.vercel/
web/*.tsbuildinfo
web/next-env.d.ts

# Hardhat compilation and test outputs
contracts/artifacts/
contracts/cache/
contracts/coverage/
contracts/coverage.json
contracts/.openzeppelin/
contracts/typechain/
contracts/typechain-types/
gasReporterOutput.txt

# Local configuration and environment secrets
.env
.env.*
!.env.example
*.pem
*.key
*.keystore

# Linting cache
.eslintcache
web/.eslintcache

# Logs and diagnostics
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# OS and IDE configuration files
.DS_Store
Thumbs.db
.idea/
.vscode/
.fleet/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp
*.swo

# Local simulated DBs and session credentials
.circle-session.json
*.json-db
*db.json
web/*_db.json
web/telemetry_db.json
web/agents_db.json

